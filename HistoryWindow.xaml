<Window x:Class="PersonalizedEmailSender.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send History"
        Width="1040"
        Height="680"
        MinWidth="860"
        MinHeight="560"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="HistoryMetricButton" TargetType="Button">
            <Setter Property="Width" Value="76"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MetricButtonFrame"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="2"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MetricButtonFrame" Property="BorderBrush" Value="#93C5FD"/>
                                <Setter TargetName="MetricButtonFrame" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8"
                                                          ShadowDepth="1"
                                                          Direction="270"
                                                          Opacity="0.18"
                                                          Color="#2563EB"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MetricButtonFrame" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="MetricButtonFrame" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="MetricButtonFrame" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HistoryContextMenuItem" TargetType="MenuItem">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <Grid Height="26">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="IconCellBorder"
                                        Grid.Column="0"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="0,0,1,0">
                                    <ContentPresenter ContentSource="Icon"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  Margin="4,0,12,0"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#DDEBFF"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#7DB7FF"/>
                                <Setter TargetName="IconCellBorder" Property="BorderBrush" Value="#7DB7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Send history"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                <TextBlock Text="Select a send run on the left to review sent email details."
                           FontSize="13"
                           Foreground="#4B5563"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button x:Name="TotalMetricButton"
                        Style="{StaticResource HistoryMetricButton}"
                        ToolTip="Show total emails"
                        Click="ShowTotal_Click">
                    <Border Background="#EFF6FF"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6">
                        <StackPanel>
                            <TextBlock Text="Total" Foreground="#4B5563" TextAlignment="Center"/>
                            <TextBlock x:Name="TotalTextBlock" Text="0" FontSize="18" FontWeight="SemiBold" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>
                <Button x:Name="SuccessMetricButton"
                        Style="{StaticResource HistoryMetricButton}"
                        ToolTip="Show successful emails"
                        Click="ShowSuccess_Click">
                    <Border Background="#ECFDF5"
                            BorderBrush="#A7F3D0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6">
                        <StackPanel>
                            <TextBlock Text="Success" Foreground="#4B5563" TextAlignment="Center" TextWrapping="NoWrap"/>
                            <TextBlock x:Name="SuccessTextBlock" Text="0" FontSize="18" FontWeight="SemiBold" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>
                <Button x:Name="FailedMetricButton"
                        Style="{StaticResource HistoryMetricButton}"
                        ToolTip="Show failed emails"
                        Click="ShowFailed_Click">
                    <Border Background="#FEF2F2"
                            BorderBrush="#FECACA"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,6">
                        <StackPanel>
                            <TextBlock Text="Failed" Foreground="#4B5563" TextAlignment="Center"/>
                            <TextBlock x:Name="FailedTextBlock" Text="0" FontSize="18" FontWeight="SemiBold" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

                <Button Content="&lt;"
                        Width="42"
                        Height="34"
                        Margin="16,0,0,0"
                        Click="PreviousEmail_Click"/>
                <TextBlock x:Name="EmailPositionTextBlock"
                           Width="90"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <Button Content="&gt;"
                        Width="42"
                        Height="34"
                        Click="NextEmail_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF"
                    BorderBrush="#E1E5EA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="History"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="SortHistoryButton"
                                Grid.Column="1"
                                Content="Newest v"
                                Width="82"
                                Height="30"
                                Padding="10,6"
                                Click="SortHistory_Click"/>
                    </Grid>

                    <ListBox x:Name="HistoryListBox"
                             Grid.Row="1"
                             Margin="0,12,0,0"
                             BorderBrush="#CBD5E1"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PreviewMouseRightButtonDown="HistoryListBox_PreviewMouseRightButtonDown"
                             SelectionChanged="HistoryListBox_SelectionChanged">
                        <ListBox.ContextMenu>
                            <ContextMenu Padding="0">
                                <MenuItem Header="Delete"
                                          Style="{StaticResource HistoryContextMenuItem}"
                                          Click="DeleteHistory_Click">
                                    <MenuItem.Icon>
                                        <Viewbox Width="16"
                                                 Height="16"
                                                 Stretch="Uniform"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                                            <Canvas Width="16" Height="16">
                                                <Path Stroke="#111827"
                                                      StrokeThickness="1.2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Data="M3,4.5 L13,4.5 M6.2,4.5 L6.7,2.8 L9.3,2.8 L9.8,4.5 M4.5,5.8 L5.2,13.2 L10.8,13.2 L11.5,5.8 M7,7.1 L7,11.5 M9,7.1 L9,11.5"/>
                                            </Canvas>
                                        </Viewbox>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10"
                                        Margin="2"
                                        BorderBrush="#E1E5EA"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplaySentAt}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"/>
                                        <TextBlock Text="{Binding DisplaySubject}"
                                                   Foreground="#4B5563"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="230"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="#FFFFFF"
                    BorderBrush="#E1E5EA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SelectedHistorySubjectTextBlock"
                               Foreground="#4B5563"
                               TextWrapping="Wrap"/>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="To" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="RecipientTextBox" IsReadOnly="True" Padding="10,7" BorderBrush="#CBD5E1" Background="#F8FAFC"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,12,0,0">
                            <TextBlock Text="Subject" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="SubjectTextBox" IsReadOnly="True" Padding="10,7" BorderBrush="#CBD5E1" Background="#F8FAFC"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,12,0,0">
                            <TextBlock Text="Attachments" Style="{StaticResource FormLabel}"/>
                            <ListBox x:Name="AttachmentFilesListBox"
                                     MinHeight="46"
                                     MaxHeight="90"
                                     Padding="4"
                                     BorderBrush="#CBD5E1"
                                     SelectionMode="Single"
                                     MouseDoubleClick="OpenAttachment_Click">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8FAFC"
                                                BorderBrush="#CBD5E1"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="9,7"
                                                Margin="3"
                                                ToolTip="{Binding FilePath}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Icon}" Width="20" Height="20" Margin="0,0,7,0"/>
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <Grid Grid.Row="3" Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Body" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="BodyTextBox"
                                     Grid.Row="1"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="10"
                                     BorderBrush="#CBD5E1"
                                     Background="#FFFFFF"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E1E5EA" BorderThickness="1" CornerRadius="8" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="HistoryStatusTextBlock"
                           Foreground="#4B5563"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Close"
                        Padding="16,8"
                        Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
