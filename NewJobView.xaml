<UserControl x:Class="PersonalizedEmailSender.NewJobView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="PathBox" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PickerButton" TargetType="Button">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="New personalized email sending"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                <TextBlock Text="Each setup here becomes its own independent job."
                           FontSize="14"
                           Foreground="#4B5563"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Close"
                    Padding="16,8"
                    VerticalAlignment="Top"
                    Click="Back_Click"/>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="0,24,0,20" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="#FFFFFF" BorderBrush="#E1E5EA" BorderThickness="1" CornerRadius="8" Padding="22">
                    <StackPanel>
                        <TextBlock Text="Job components"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>

                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Style="{StaticResource FormLabel}">
                                <Run Text="Recipient file"/><Run Text=" *" Foreground="#DC2626"/>
                            </TextBlock>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="RecipientFileTextBox" Style="{StaticResource PathBox}"/>
                                <Button Grid.Column="1" Content="Browse" Style="{StaticResource PickerButton}" Click="BrowseRecipient_Click"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="Word template file" Style="{StaticResource FormLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TemplateFileTextBox" Style="{StaticResource PathBox}"/>
                                <Button Grid.Column="1" Content="Browse" Style="{StaticResource PickerButton}" Click="BrowseTemplate_Click"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Style="{StaticResource FormLabel}">
                                <Run Text="Output folder"/><Run Text=" *" Foreground="#DC2626"/>
                            </TextBlock>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OutputFolderTextBox" Style="{StaticResource PathBox}"/>
                                <Button Grid.Column="1" Content="Browse" Style="{StaticResource PickerButton}" Click="BrowseOutputFolder_Click"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="Common attachment files" Style="{StaticResource FormLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ListBox x:Name="AttachmentsListBox"
                                         MinHeight="72"
                                         MaxHeight="130"
                                         Padding="6"
                                         BorderBrush="#CBD5E1"
                                         Background="#FFFFFF"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8FAFC"
                                                    BorderBrush="#CBD5E1"
                                                    BorderThickness="1"
                                                    CornerRadius="5"
                                                    Padding="9,7"
                                                    Margin="3"
                                                    ToolTip="{Binding FilePath}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{Binding Icon}" Width="20" Height="20" Margin="0,0,7,0"/>
                                                    <TextBlock Text="{Binding FileName}"
                                                               VerticalAlignment="Center"
                                                               MaxWidth="210"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel Grid.Column="1">
                                    <Button Content="Add" Style="{StaticResource PickerButton}" Click="AddAttachments_Click"/>
                                    <Button Content="Clear" Style="{StaticResource PickerButton}" Margin="10,8,0,0" Click="ClearAttachments_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E1E5EA" BorderThickness="1" CornerRadius="8" Padding="22">
                    <StackPanel>
                        <TextBlock Text="Email fields"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <TextBlock x:Name="ColumnStatusTextBlock"
                                   Text="Choose a recipient file to load column names."
                                   FontSize="13"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,18"/>

                        <TextBlock Style="{StaticResource FormLabel}">
                            <Run Text="Recipient email column"/><Run Text=" *" Foreground="#DC2626"/>
                        </TextBlock>
                        <ComboBox x:Name="EmailColumnComboBox" MinHeight="34" Margin="0,0,0,14"/>

                        <TextBlock Text="Available recipient columns"
                                   Style="{StaticResource FormLabel}"
                                   Margin="0,10,0,6"/>
                        <ListBox x:Name="ColumnsListBox" MinHeight="160" BorderBrush="#CBD5E1"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E1E5EA" BorderThickness="1" CornerRadius="8" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Create Job validates the selected files and prepares the independent job workspace."
                               Foreground="#4B5563"
                               TextWrapping="Wrap"/>
                    <TextBlock Margin="0,5,0,0" Foreground="#4B5563">
                        <Run Text="*" Foreground="#DC2626" FontWeight="SemiBold"/>
                        <Run Text=" Required fields must be selected before creating a job."/>
                    </TextBlock>
                    <TextBlock Margin="0,5,0,0"
                               Text="Only one Word template can be selected. The Word template (or converted PDF) and all common attachments cannot exceed 20 MB in total."
                               Foreground="#4B5563"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Create Job"
                        Padding="20,9"
                        FontWeight="SemiBold"
                        Click="CreateJob_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
