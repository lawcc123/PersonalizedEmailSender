<Window x:Class="PersonalizedEmailSender.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Personalized Email Sender"
        Width="1160"
        Height="760"
        MinWidth="960"
        MinHeight="660"
        Background="#F6F7F9"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PrimaryOptionButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D6DAE1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                                <Setter Property="Background" Value="#F8FAFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EEF4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E1E5EA" BorderThickness="0,0,0,1">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Personalized Email Sender"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                    <TextBlock Text="Condo notice automation"
                               FontSize="12"
                               Foreground="#6B7280"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Settings" Padding="14,7" Margin="0,0,8,0" Click="Settings_Click"/>
                    <Button Content="Help" Padding="14,7"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="32">
            <Grid x:Name="HomeView">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="What would you like to do?"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                    <TextBlock Text="Choose a starting point for your notice campaign."
                               FontSize="14"
                               Foreground="#4B5563"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,28,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource PrimaryOptionButton}" Margin="0,0,16,0" Click="CreateNew_Click">
                        <StackPanel>
                            <TextBlock Text="1" FontSize="13" FontWeight="SemiBold" Foreground="#2563EB"/>
                            <TextBlock Text="Create a new personalized email sending"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       TextWrapping="Wrap"
                                       Margin="0,18,0,0"/>
                            <TextBlock Text="Start a new campaign, choose the recipient file, Word template, attachments, and output folder."
                                       FontSize="14"
                                       Foreground="#4B5563"
                                       TextWrapping="Wrap"
                                       LineHeight="21"
                                       Margin="0,14,0,0"/>
                            <TextBlock Text="Next step: campaign setup"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#1D4ED8"
                                       Margin="0,26,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1" Style="{StaticResource PrimaryOptionButton}" Margin="8,0,8,0" Click="ContinueExisting_Click">
                        <StackPanel>
                            <TextBlock Text="2" FontSize="13" FontWeight="SemiBold" Foreground="#047857"/>
                            <TextBlock Text="Continue the existing email work"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       TextWrapping="Wrap"
                                       Margin="0,18,0,0"/>
                            <TextBlock Text="Open a saved campaign folder and continue generating PDFs, creating drafts, or reviewing errors."
                                       FontSize="14"
                                       Foreground="#4B5563"
                                       TextWrapping="Wrap"
                                       LineHeight="21"
                                       Margin="0,14,0,0"/>
                            <TextBlock Text="Next step: select campaign"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#047857"
                                       Margin="0,26,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Style="{StaticResource PrimaryOptionButton}" Margin="16,0,0,0" Click="ViewHistory_Click">
                        <StackPanel>
                            <TextBlock Text="3" FontSize="13" FontWeight="SemiBold" Foreground="#9333EA"/>
                            <TextBlock Text="View history"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       TextWrapping="Wrap"
                                       Margin="0,18,0,0"/>
                            <TextBlock Text="Review past campaign logs, generated documents, Outlook results, and send history."
                                       FontSize="14"
                                       Foreground="#4B5563"
                                       TextWrapping="Wrap"
                                       LineHeight="21"
                                       Margin="0,14,0,0"/>
                            <TextBlock Text="Next step: history records"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#7E22CE"
                                       Margin="0,26,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E1E5EA" BorderThickness="0,1,0,0">
            <Grid Margin="28,0">
                <TextBlock x:Name="StatusTextBlock"
                           Text="Ready."
                           FontSize="12"
                           Foreground="#6B7280"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
