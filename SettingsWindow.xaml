<Window x:Class="PersonalizedEmailSender.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Settings"
        Width="560"
        Height="600"
        MinWidth="500"
        MinHeight="500"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Settings"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>
            <TextBlock Text="These settings are remembered on this computer."
                       FontSize="13"
                       Foreground="#4B5563"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#E1E5EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,18,0,18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Signature" FontSize="17" FontWeight="SemiBold" Foreground="#111827"/>

                <CheckBox x:Name="SignatureEnabledCheckBox"
                          Content="Add signature to email"
                          Margin="0,14,0,0"
                          Checked="SignatureOption_Changed"
                          Unchecked="SignatureOption_Changed"/>

                <StackPanel x:Name="AppManagedSignaturePanel">
                    <TextBlock Text="Signature text" Style="{StaticResource FormLabel}" Margin="0,18,0,6"/>
                    <TextBlock Text="Type the signature exactly as you want it to appear at the bottom of the email."
                               Foreground="#4B5563"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="AppManagedSignatureTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Height="150"
                             Padding="10"
                             BorderBrush="#CBD5E1"
                             Background="#FFFFFF"
                             TextChanged="AppManagedSignatureTextBox_TextChanged"/>

                    <TextBlock Text="Signature picture" Style="{StaticResource FormLabel}" Margin="0,18,0,6"/>
                    <TextBlock Text="Choose one image file to place under the signature text. Drag the lower-right handle to resize it."
                               Foreground="#4B5563"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <Border x:Name="SignatureImagePreviewBorder"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            Background="#F8FAFC"
                            Padding="10"
                            MinHeight="88"
                            Margin="0,0,0,10">
                        <Grid HorizontalAlignment="Left"
                              VerticalAlignment="Top">
                            <Image x:Name="SignatureImagePreview"
                                   Width="260"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"/>
                            <Border x:Name="SignatureImageResizeBorder"
                                    BorderBrush="#2563EB"
                                    BorderThickness="1"
                                    Visibility="Collapsed">
                                <Grid>
                                    <primitives:Thumb x:Name="SignatureImageResizeThumb"
                                                      Width="12"
                                                      Height="12"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Bottom"
                                                      Cursor="SizeNWSE"
                                                      DragDelta="SignatureImageResizeThumb_DragDelta">
                                        <primitives:Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                                                <Border Background="#2563EB"
                                                        BorderBrush="#FFFFFF"
                                                        BorderThickness="1"/>
                                            </ControlTemplate>
                                        </primitives:Thumb.Template>
                                    </primitives:Thumb>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="NoSignatureImageTextBlock"
                                       Text="No signature picture selected"
                                       Foreground="#64748B"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SignatureImageFileNameTextBlock"
                                   Foreground="#4B5563"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1"
                                Content="Browse"
                                Padding="14,8"
                                Margin="10,0,0,0"
                                Click="BrowseSignatureImage_Click"/>
                        <Button Grid.Column="2"
                                Content="Clear"
                                Padding="14,8"
                                Margin="8,0,0,0"
                                Click="ClearSignatureImage_Click"/>
                    </Grid>
                </StackPanel>

                <TextBlock x:Name="SignatureHelpTextBlock"
                           Margin="0,10,0,0"
                           Foreground="#4B5563"
                           TextWrapping="Wrap"/>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E1E5EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="The app-managed signature is appended to each email before Outlook opens or sends it."
                           Foreground="#4B5563"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Close"
                        Padding="16,8"
                        Margin="12,0,10,0"
                        Click="Close_Click"/>
                <Button Grid.Column="2"
                        Content="Save"
                        Padding="18,8"
                        FontWeight="SemiBold"
                        Click="Save_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
