<Window x:Class="PersonalizedEmailSender.NewJobWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PersonalizedEmailSender"
        Title="New Personalized Email Sending"
        Width="1060"
        Height="690"
        MinWidth="920"
        MinHeight="620"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <local:NewJobView x:Name="NewJobScreen"
                          Margin="28"
                          BackRequested="NewJobScreen_BackRequested"
                          JobCreated="NewJobScreen_JobCreated"
                          StatusChanged="NewJobScreen_StatusChanged"/>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E1E5EA" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <TextBlock x:Name="StatusTextBlock"
                           Text="New independent job setup started."
                           FontSize="12"
                           Foreground="#6B7280"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
