<Window x:Class="PersonalizedEmailSender.EmailPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Email Preview"
        Width="900"
        Height="720"
        MinWidth="760"
        MinHeight="560"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Email preview"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                <TextBlock Text="Review one generated email at a time. Outlook opens only for the current preview."
                           FontSize="13"
                           Foreground="#4B5563"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Content="&lt;"
                        Width="42"
                        Height="34"
                        Click="Previous_Click"/>
                <TextBlock x:Name="PositionTextBlock"
                           Width="90"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <Button Content="&gt;"
                        Width="42"
                        Height="34"
                        Click="Next_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,18,0,18"
                Padding="16"
                Background="#FFFFFF"
                BorderBrush="#E1E5EA"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="To" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="RecipientTextBox"
                             IsReadOnly="True"
                             Padding="10,7"
                             BorderBrush="#CBD5E1"
                             Background="#F8FAFC"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,14,0,0">
                    <TextBlock Text="Subject" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="SubjectTextBox"
                             IsReadOnly="True"
                             Padding="10,7"
                             BorderBrush="#CBD5E1"
                             Background="#F8FAFC"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                    <TextBlock Text="Attachments" Style="{StaticResource FormLabel}"/>
                    <ListBox x:Name="AttachmentFilesListBox"
                             MinHeight="48"
                             MaxHeight="110"
                             Padding="4"
                             BorderBrush="#CBD5E1"
                             Background="#FFFFFF"
                             SelectionMode="Single"
                             MouseDoubleClick="OpenAttachment_Click"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8FAFC"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="9,7"
                                        Margin="3"
                                        ToolTip="{Binding FilePath}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding Icon}" Width="20" Height="20" Margin="0,0,7,0"/>
                                        <TextBlock Text="{Binding FileName}"
                                                   VerticalAlignment="Center"
                                                   MaxWidth="220"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,14,0,0">
                    <TextBlock Text="Body" Style="{StaticResource FormLabel}"/>
                    <TextBlock x:Name="SignatureNoticeTextBlock"
                               Foreground="#4B5563"
                               Margin="0,0,0,6"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                    <TextBox x:Name="BodyTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"
                             BorderBrush="#CBD5E1"
                             Background="#FFFFFF"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E1E5EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Double-click an attachment to open it. Open In Outlook creates only the current email."
                           Foreground="#4B5563"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Open In Outlook"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        FontWeight="SemiBold"
                        Click="OpenCurrentInOutlook_Click"/>
                <Button Grid.Column="2"
                        Content="Send to All"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        FontWeight="SemiBold"
                        Click="SendToAll_Click"/>
                <Button Grid.Column="3"
                        Content="Close"
                        Padding="16,8"
                        Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
