<Window x:Class="PersonalizedEmailSender.EmailPreparationProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preparing Emails"
        Width="460"
        Height="210"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F6F7F9">
    <Border Margin="20"
            Padding="18"
            Background="#FFFFFF"
            BorderBrush="#E1E5EA"
            BorderThickness="1"
            CornerRadius="8">
        <StackPanel>
            <TextBlock Text="Working..."
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>
            <TextBlock x:Name="StatusTextBlock"
                       Text="Starting..."
                       Margin="0,8,0,14"
                       Foreground="#4B5563"
                       TextWrapping="Wrap"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="52"/>
                </Grid.ColumnDefinitions>

                <Border Height="22"
                        Background="#E5E7EB"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="4"
                        ClipToBounds="True">
                    <Grid x:Name="ProgressTrackGrid"
                          SizeChanged="ProgressTrackGrid_SizeChanged">
                        <Border x:Name="ProgressFillBorder"
                                Width="0"
                                Background="#2563EB"
                                HorizontalAlignment="Left"
                                CornerRadius="3"/>
                    </Grid>
                </Border>

                <TextBlock x:Name="ProgressPercentTextBlock"
                           Grid.Column="1"
                           Text="0%"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           TextAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <TextBlock x:Name="ProgressBarTextBlock"
                       Text="--------------------"
                       Margin="0,8,0,0"
                       FontFamily="Consolas"
                       FontSize="13"
                       Foreground="#2563EB"/>
        </StackPanel>
    </Border>
</Window>
