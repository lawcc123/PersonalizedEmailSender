<Window x:Class="PersonalizedEmailSender.RecipientPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recipient List"
        Width="900"
        Height="560"
        MinWidth="720"
        MinHeight="460"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Recipient list"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>
            <TextBlock x:Name="RecipientCountTextBlock"
                       FontSize="13"
                       Foreground="#4B5563"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <DataGrid x:Name="RecipientsDataGrid"
                  Grid.Row="1"
                  Margin="0,18,0,18"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="#FFFFFF"
                  BorderBrush="#CBD5E1"
                  AutoGeneratingColumn="RecipientsDataGrid_AutoGeneratingColumn"/>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E1E5EA" BorderThickness="1" CornerRadius="8" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="This preview is read-only. The blue highlighted column will be used to send email."
                           Foreground="#4B5563"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Refresh recipient file"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        Click="RefreshRecipientFile_Click"/>
                <Button Grid.Column="2"
                        Content="Close"
                        Padding="16,8"
                        Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
