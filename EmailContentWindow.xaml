<Window x:Class="PersonalizedEmailSender.EmailContentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Email Content"
        Width="860"
        Height="790"
        MinWidth="760"
        MinHeight="690"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="ModernScrollBarRepeatButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="#CBD5E1"
                                CornerRadius="3"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="MinWidth" Value="5"/>
            <Setter Property="MaxWidth" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource ModernScrollBarRepeatButton}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource ModernScrollBarRepeatButton}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="MinWidth" Value="0"/>
                    <Setter Property="MaxWidth" Value="100000"/>
                    <Setter Property="Height" Value="5"/>
                    <Setter Property="MinHeight" Value="5"/>
                    <Setter Property="MaxHeight" Value="5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Email title and body"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                <TextBlock Text="Write the content that will be used for this independent sending job."
                           FontSize="14"
                           Foreground="#4B5563"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="20,0"
                        VerticalAlignment="Top">
                <TextBlock Text="Insert field" Style="{StaticResource FormLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="MergeFieldComboBox"
                              Height="36"
                              Padding="8,0"
                              VerticalContentAlignment="Center">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <EventSetter Event="PreviewMouseLeftButtonUp"
                                             Handler="MergeFieldComboBoxItem_PreviewMouseLeftButtonUp"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                    <Button Grid.Column="1"
                            Content="Insert Field"
                            Height="36"
                            Padding="14,0"
                            Margin="10,0,0,0"
                            Click="InsertField_Click"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                <TextBlock x:Name="RecipientCountTextBlock"
                           Text="0 recipient(s) loaded"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           HorizontalAlignment="Right"/>
                <Button Content="View Recipients"
                        Height="36"
                        Padding="14,0"
                        Margin="0,8,0,0"
                        Click="ViewRecipients_Click"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="0,24,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Email title / subject" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="SubjectTextBox"
                             Padding="10,8"
                             BorderBrush="#CBD5E1"
                             Background="#FFFFFF"
                             VerticalContentAlignment="Center"
                             PreviewMouseLeftButtonDown="EditableTextBox_PreviewMouseLeftButtonDown"/>
                </StackPanel>

                <Border Background="#FFFFFF"
                        BorderBrush="#E1E5EA"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,18,0">
                            <TextBlock Text="Word template file" Style="{StaticResource FormLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <Border Background="#F8FAFC"
                                            BorderBrush="#CBD5E1"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="9,7"
                                            MinHeight="38"
                                            ToolTip="{Binding ElementName=TemplateFileNameTextBlock, Path=Tag}">
                                        <StackPanel Orientation="Horizontal">
                                            <Image x:Name="TemplateFileIconImage"
                                                   Width="20"
                                                   Height="20"
                                                   Margin="0,0,7,0"/>
                                            <TextBlock x:Name="TemplateFileNameTextBlock"
                                                       Text="No Word template selected"
                                                       VerticalAlignment="Center"
                                                       Foreground="#4B5563"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBox x:Name="WordOutputFileNameTextBox"
                                             Padding="10,7"
                                             Margin="0,8,0,0"
                                             BorderBrush="#CBD5E1"
                                             Background="#FFFFFF"
                                             Foreground="#6B7280"
                                             VerticalContentAlignment="Center"
                                             PreviewMouseLeftButtonDown="EditableTextBox_PreviewMouseLeftButtonDown"
                                             GotFocus="WordOutputFileNameTextBox_GotFocus"
                                             LostFocus="WordOutputFileNameTextBox_LostFocus"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <Button Content="Browse"
                                            Width="84"
                                            Height="38"
                                            Padding="14,7"
                                            Click="BrowseTemplate_Click"/>
                                    <Button Content="Open"
                                            Width="84"
                                            Height="38"
                                            Padding="14,7"
                                            Margin="0,8,0,0"
                                            Click="OpenWordTemplate_Click"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <CheckBox x:Name="ConvertToPdfCheckBox"
                                          Content="Convert the document to PDF"
                                          IsChecked="True"
                                          VerticalAlignment="Center"
                                          Checked="ConvertToPdfCheckBox_Changed"
                                          Unchecked="ConvertToPdfCheckBox_Changed"/>
                                <StackPanel x:Name="ConversionPreviewPanel"
                                            Orientation="Horizontal"
                                            Margin="10,0,0,0"
                                            Visibility="Hidden">
                                    <Image x:Name="TemplateConversionWordIconImage"
                                           Width="20"
                                           Height="20"
                                           Margin="0,0,6,0"/>
                                    <TextBlock Text="-&gt;"
                                               FontSize="16"
                                               Foreground="#4B5563"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <Image x:Name="TemplateConversionPdfIconImage"
                                           Width="20"
                                           Height="20"
                                           Margin="0,0,6,0"/>
                                    <TextBlock Text="PDF"
                                               Foreground="#4B5563"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Common attachment files" Style="{StaticResource FormLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ListBox x:Name="AttachmentFilesListBox"
                                         MinHeight="44"
                                         MaxHeight="110"
                                         Padding="4"
                                         BorderBrush="#CBD5E1"
                                         Background="#FFFFFF"
                                         SelectionMode="Single"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8FAFC"
                                                    BorderBrush="#CBD5E1"
                                                    BorderThickness="1"
                                                    CornerRadius="5"
                                                    Padding="9,7"
                                                    Margin="3"
                                                    ToolTip="{Binding FilePath}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{Binding Icon}" Width="20" Height="20" Margin="0,0,7,0"/>
                                                    <TextBlock Text="{Binding FileName}"
                                                               VerticalAlignment="Center"
                                                               MaxWidth="190"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <Button Content="Add"
                                            Width="64"
                                            Height="44"
                                            Padding="14,7"
                                            Click="AddAttachments_Click"/>
                                    <Button Content="Clear"
                                            Width="64"
                                            Height="44"
                                            Padding="14,7"
                                            Margin="0,8,0,0"
                                            Click="ClearAttachments_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel>
                    <TextBlock Text="Email body" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="BodyTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"
                             BorderBrush="#CBD5E1"
                             Background="#FFFFFF"
                             PreviewMouseLeftButtonDown="EditableTextBox_PreviewMouseLeftButtonDown"
                             TextChanged="BodyTextBox_TextChanged"
                             Height="140"
                             MinHeight="140"
                             MaxHeight="280"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#E1E5EA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Margin="0,0,12,0" Foreground="#4B5563" TextWrapping="Wrap">
                        <Run Text="In the Word template, type merge fields as {{ColumnName}} and make sure the name matches a recipient column."/>
                        <LineBreak/>
                        <Run Text="Only one Word template can be selected."/>
                        <LineBreak/>
                        <Run Text="The Word template (or converted PDF) and all common attachments cannot exceed 20 MB in total."/>
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Cancel"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"/>
                <Button Grid.Column="2"
                        Content="Save Draft"
                        Padding="18,8"
                        Margin="0,0,10,0"
                        FontWeight="SemiBold"
                        Click="SaveDraft_Click"/>
                <Button Grid.Column="3"
                        Content="Continue to Email Preview"
                        Padding="18,8"
                        FontWeight="SemiBold"
                        Click="SendEmail_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
