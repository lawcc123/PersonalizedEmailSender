<Window x:Class="PersonalizedEmailSender.DraftListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Saved Drafts"
        Width="720"
        Height="520"
        MinWidth="620"
        MinHeight="420"
        Background="#F6F7F9"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Saved drafts"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>
            <TextBlock x:Name="DraftFolderTextBlock"
                       FontSize="13"
                       Foreground="#4B5563"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E1E5EA" BorderThickness="1" CornerRadius="8" Margin="0,18,0,18">
            <ListBox x:Name="DraftsListBox"
                     BorderThickness="0"
                     MouseDoubleClick="DraftsListBox_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="10,8">
                            <TextBlock Text="{Binding DisplayTitle}"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                            <TextBlock Text="{Binding DisplayDetails}"
                                       Foreground="#4B5563"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E1E5EA" BorderThickness="1" CornerRadius="8" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusTextBlock"
                           Text="Choose a draft to continue."
                           Foreground="#4B5563"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Cancel"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"/>
                <Button Grid.Column="2"
                        Content="Delete Draft"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        Foreground="#B91C1C"
                        Click="DeleteDraft_Click"/>
                <Button Grid.Column="3"
                        Content="Open Draft"
                        Padding="18,8"
                        FontWeight="SemiBold"
                        Click="OpenDraft_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
